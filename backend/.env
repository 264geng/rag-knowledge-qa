# DeepSeek API 配置
OPENAI_API_KEY=sk-056c26682b0046c7b0326f157525f526
OPENAI_BASE_URL=https://api.deepseek.com

# 模型选择（DeepSeek 模型）
LLM_MODEL=deepseek-chat

# Embedding 配置（火山方舟 API）
EMBEDDING_PROVIDER=volcengine
EMBEDDING_MODEL=doubao-embedding-vision-251215
EMBEDDING_API_KEY=ark-4467321d-3bf0-4a71-8842-b88a7faad9bc-4d8e4
EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 混合检索配置
HYBRID_SEARCH_ENABLED=true
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# Rerank 配置
RERANK_ENABLED=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_K=4

# JWT 配置
JWT_SECRET_KEY=campus-rag-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# 数据库配置
DATABASE_PATH=data/rag_knowledge.db

# 文件上传配置
UPLOAD_DIR=data/uploads
MAX_FILE_SIZE_MB=10

# RAG 参数
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=4

# ChromaDB 持久化路径
CHROMA_PERSIST_DIR=data/chroma_db

# 管理员默认账户
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
